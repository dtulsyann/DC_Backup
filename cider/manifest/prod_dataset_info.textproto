dataset_source: {
  name: "Resources for the Future (RFF)"
  url: "https://www.rff.org/"
  # TODO(shanth): Get a better URL from the RFF team.
  datasets: [
    {
      name: "US Historical Weather Variability - 4km resolution"
      url: "https://www.rff.org/publications/data-tools/"
      description_md: "Includes U.S. historical weather variability at 4 KM resolution for daily min/max temperature and precipitation. Additionally includes statistics for heavy precipitation index and consecutive dry days variables."
      verticals: ["Environment"]
    },
    {
      name: "US Historical Weather Variability - County"
      url: "https://www.rff.org/publications/data-tools/"
      description_md: "Includes U.S. county-level historical weather variability for daily min/max temperature and precipitation. Additionally includes statistics for heavy precipitation index and consecutive dry days variables, aggregated by RFF from stats at 4 KM resolution."
      verticals: ["Environment"]
    },
    {
      name: "US Forecast Weather Variability - 0.25 degree resolution"
      url: "https://www.rff.org/publications/data-tools/"
      description_md: "Includes forecasts (until 2100) of U.S. weather variability at 0.25 degree resolution for daily min/max temperature and precipitation. Additionally includes statistics for heavy precipitation index and consecutive dry days variables."
      verticals: ["Environment"]
    },
    {
      name: "US Forecast Weather Variability - County"
      url: "https://www.rff.org/publications/data-tools/"
      description_md: "Includes forecasts (until 2100) of U.S. county-level weather variability for daily min/max temperature and precipitation."
      verticals: ["Environment"]
    },
    {
      name: "US Geo Grids for RFF"
      url: "https://www.rff.org/publications/data-tools/"
      description_md: "Includes geo grid places in the U.S. at 0.25 degree resolution and 4km resolution."
      verticals: ["Environment"]
    },
    {
      name: "US Wildfire, Smoke and Drought statistics - County and State"
      url: "https://www.rff.org/publications/data-tools/"
      description_md:
        "This dataset incorporates statistics aggregated by RFF from the following sources:\n"
        "* [PRISM Climate Group, Oregon State University](https://prism.oregonstate.edu/recent/): Temperature, precipitation, and vapor pressure deficit data\n"
        "* [gridMET](http://thredds.northwestknowledge.net/thredds/reacch_climate_MET_aggregated_catalog.html?dataset=agg_met_pdsi_1979_CurrentYear_CONUS): Palmer Drought Severity Index (PDSI) data\n"
        "* [Parks & Abatzoglou (2020)](https://datadryad.org/stash/dataset/doi:10.5061/dryad.tmpg4f4x1): Data on forest cover and fire severity in the western U.S.\n"
        "* [U.S. Census Bureau](https://www2.census.gov/programs-surveys/popest/datasets/2020-2021/counties/totals/): County-level population estimates\n"
        "* MTBS Project (USDA Forest Service/U.S. Geological Survey)(http://mtbs.gov/direct-download): Fire-level geospatial data\n"
        "* [Childs et al. 2022](https://www.stanfordecholab.com/wildfire_smoke): Data on PM2.5 from wildfire smoke\n"
      verticals: ["Environment"]
    }
  ]
  footer_md: "All data is made available for non-commercial purposes only."
}
