dataset_source: {
  name: "United States Geological Service (USGS)"
  url: "https://www.usgs.gov/"
  datasets: [
    {
      name: "Advanced National Seismic System Comprehensive Earthquake Catalog (ComCat)"
      url: "https://earthquake.usgs.gov/data/comcat"
      description_md: "Earthquake source parameters (e.g. hypocenters, magnitudes, phase picks and amplitudes) and other data (e.g. moment tensor solutions, macroseismic information, tectonic summaries, maps) produced by contributing seismic networks. Data Commons includes date, time, location, magnitudes, magnitude errors, depth, depth error, and review status of earthquakes of magnitude 3 onwards starting from 1900.\n"
      verticals: ["Environment"]
    },
    {
      name: "Geographic Names Information System (GNIS) - National Federal Codes"
      url: "https://www.usgs.gov/us-board-on-geographic-names/download-gnis-data"
      description_md: "Codes, names, coordinates, and more information for all named physical and cultural geographic features (except roads and highways) of the United States. Data Commons uses this dataset to build containment relationships between places from the [U.S. Census Gazetteer](https://www.census.gov/geographies/reference-files/time-series/geo/gazetteer-files.html) dataset.\n"
      verticals: ["Environment"]
    },
    {
      name: "National Water Use Data"
      url: "https://waterdata.usgs.gov/nwis/wu"
      description_md: "Water use data for states and counties in the U.S., broken down by water source (ground water, surface water), water type (fresh water, saline water), and category of use (domestic, industrial, etc.).\n"
      verticals: ["Environment"]
    }
  ]
  footer_md: "[Copyrights and credits terms of service](https://www.usgs.gov/information-policies-and-instructions/copyrights-and-credits)\n"
}
dataset_source: {
