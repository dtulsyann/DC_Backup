dataset_source: {
  name: "World Health Organization (WHO)"
  url: "https://www.who.int/"
  datasets: [
    {
      name: "ATC Codes"
      url: "https://www.whocc.no/atc_ddd_index/"
      description_md: "Anatomical Therapeutic Chemical (ATC) is a heirarchical classification system for pharmacological substances. 'In the ATC classification system, the active substances are classified in a hierarchy with five different levels. The system has fourteen main anatomical/pharmacological groups or 1st levels. Each ATC main group is divided into 2nd levels which could be either pharmacological or therapeutic groups. The 3rd and 4th levels are chemical, pharmacological or therapeutic subgroups and the 5th level is the chemical substance. The 2nd, 3rd and 4th levels are often used to identify pharmacological subgroups when that is considered more appropriate than therapeutic or chemical subgroups.'\n"
      verticals: ["Biomedical"]
    },
    {
      name: "Coronavirus Disease (COVID-19) Dashboard"
      url: "https://data.who.int/dashboards/covid19/"
      description_md: "COVID-19 cases and death counts for countries across the world.\n"
      verticals: ["Health"]
    },
    {
      name: "WHO Tuberculosis Bacteriologically Confirmed"
      url: "https://data.who.int/indicators/i/1891124/5D51DB1"
      description_md: "Count of new episode of pulmonary tuberculosis whose disease was bacteriologically confirmed.\n"
      verticals: ["Health"]
    },
    {
      name: "Global Health Observatory"
      url: "https://www.who.int/data/gho/data/indicators/indicators-index"
      description_md: "Data Commons imports variables about a variety of health indicators at the country level.\n"
      verticals: ["Health"]
    },
    {
      name: "WHO Data"
      url: "https://www.who.int/data"
      description_md: "UN-curated data from the World Health Organization.\n"
      verticals: ["Health"]
    },
    {
      name: "Adolescent Birth Rate"
      url: "https://data.who.int/indicators/i/24C65FE/27D371A"
      description_md: "The annual number of births to females aged 10-14 or 15-19 years per 1,000 females in the respective age group."
      verticals: ["Health"]
    },
    {
      name: "WHO Tuberculosis And HIV Treatment Outcome"
      url: "https://data.who.int/indicators/i/DCDC2EB/625E736"
      description_md: "Percentage of people with TB/HIV who started dug-susceptible tuberculosis treatment and whose treatment outcome was recorded as treatment success (cured or treatment completed), treatment failed, died, lost to follow-up, or not evaluated, within the reporting period."
      verticals: ["Health"]
    },
    {
      name: "WHO Tuberculosis Bacteriologically Confirmed Percentage"
      url: "https://data.who.int/indicators/i/1891124/5D51DB1"
      description_md: "Percentage of people diagnosed with a new episode of pulmonary TB whose disease was bacteriologically confirmed."
      verticals: ["Health"]
