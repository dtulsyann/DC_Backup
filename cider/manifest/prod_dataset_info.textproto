# proto-file: datacommons/proto/dc_manifest.proto
# proto-message: DataCommonsManifest
#
# DATASET INFO
# -----------------------
# Verticals are selected from: Agriculture, Biomedical, Crime, Demographics,
# Economy, Education, Energy, Environment, Health, Housing
#
# The "Data Commons Aggregations" dataset is a placeholder for all aggregated
# imports that incorporate multiple other datasets. Aggregated imports that are
# based on a single dataset will be tagged with the source dataset.
#
# The "Data Commons Curated" dataset is a placeholder for all imports that have
# been specially curated by Data Commons.
#
# The "Data Commons Schema" dataset is a placeholder for all imports containing
# schema.
#
# The "Data Commons Imputed" dataset is a placeholder for all imports that have
# been imputed by Data Commons.
dataset_source: {
  name: "Data Commons"
  url: "https://datacommons.org/"
  datasets: [
    {
      name: "Data Commons Aggregations"
      url: "https://datacommons.org/"
      description_md: "This dataset includes all custom aggregations by Data Commons that incorporate multiple source datasets.\n"
    },
    {
      name: "Data Commons Curated"
      url: "https://datacommons.org/"
      description_md: "This dataset includes all data that has been specially curated by Data Commons.\n"
    },
    {
      name: "Data Commons Schema"
      url: "https://datacommons.org/"
      description_md: "This dataset is a placeholder for all schema imports.\n"
    },
    {
      name: "Data Commons Imputed"
      url: "https://datacommons.org/"
      description_md: "This dataset includes all data that has been imputed by Data Commons.\n"
    },
    {
      name: "WetBulb Temperature Event"
      url: "https://datacommons.org/"
      description_md: "Places with WetBulb temperature exceeding 30 degrees Celsius as per NASA's Modern-Era Retrospective analysis for Research and Applications version 2 (MERRA-2) dataset on Google Earth Engine."
      verticals: ["Environment"]
    },
    {
      name: "Temperature Event"
      url: "https://datacommons.org/"
      description_md: "The events for places with unusual temperatures, either too hot or too cold, computed with reference to long-term temperature averages, e.g. the average maximum daily temperature in January over the years 1980-2010."
      verticals: ["Environment"]
    }
  ]
}
