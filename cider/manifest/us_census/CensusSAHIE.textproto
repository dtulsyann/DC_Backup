  category: STATS
  provenance_description: "The Small Area Health Insurance Estimates (SAHIE) program was created to develop model-based estimates of health insurance coverage for counties and states"
  # Retain historic data from 2008-2017.
  mcf_proto_url: "/cns/jv-d/home/datcom/v3_resolved_mcf/census_v2/sahie/historical/graph.tfrecord@2.gz"
