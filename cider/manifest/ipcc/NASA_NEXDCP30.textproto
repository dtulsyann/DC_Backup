  category: STATS
  provenance_description: "High-resolution downscaled climate projections for the United States based on IPCC CMIP5 scenarios."
  mcf_proto_url: "/cns/jv-d/home/datcom/v3_resolved_mcf/nasa/nex-dcp30/graph.tfrecord*"
