  start_date_in_kg: "1950"
  end_date_in_kg: "2099"
  resolution_info: { uses_id_resolver: true }
  table {
    mapping_path: "/cns/jv-d/home/datcom/v3_mcf/nasa/nex-dcp30/ipcc_geo_resolved.tmcf"
    csv_path: "/cns/jv-d/home/datcom/v3_mcf/nasa/nex-dcp30/ipcc_geo_resolved-*-of-*"
  }
  dataset_name: "NEX - Downscaled Climate Projections for US from IPCC CMIP5"
}
