  "@type": "sc:Dataset",
  "name": "Argentina Census",
  "conformsTo": "http://mlcommons.org/croissant/1.1",
  "description": "Population Census and Statistics for Brazil",
  "license": "https://www.indec.gob.ar/indec/web/Institucional-Indec-Transparencia",
  "url": "https://datacommons.org/browser/dc/d/NationalInstituteOfStatisticsAndCensusesIndec_ArgentinaCensus",
  "isLiveDataset": true,
  "dateModified": "2023-05-11",
  "creator": [
    {
      "@type": "Organization",
      "name": "National Institute of Statistics and Censuses (INDEC)",
      "url": "https://www.indec.gob.ar"
    }
  ],
  "publisher": {
    "@type": "Organization",
    "name": "Data Commons",
    "url": "https://datacommons.org"
  },
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "provenance-1",
      "name": "census_data.zip",
      "description": "A compressed archive containing all provenance CSVs for the 1980-2019 Argentina Census.",
      "contentUrl": "https://api.example.com/data/census_1.zip",
      "contentSize": "25585843 B",
      "encodingFormat": "application/zip"
    },
    {
      "@type": "cr:FileSet",
      "@id": "all-provenances",
      "name": "all-provenances",
      "containedIn": [
        {"@id": "provenance-1"}
      ],
      "encodingFormat": "text/csv",
      "includes": "*.csv"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "census-records",
      "name": "census-records",
      "field": [
        {
          "@type": "cr:Field",
          "name": "id",
          "dataType": "sc:Integer",
          "source": {
            "fileSet": {
              "@id": "all-provenances"
            },
            "extract": { "column": "column1" }
          }
        },
        {
          "@type": "cr:Field",
          "name": "district",
          "dataType": "sc:Text",
          "source": {
            "fileSet": {
              "@id": "all-provenances"
            },
            "extract": { "column": "column2" }
          }
        }
      ]
    }
  ]
